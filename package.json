{
  "name": "@kweaver-ai/kweaver-admin",
  "version": "0.6.0",
  "description": "CLI tool for KWeaver administrators",
  "type": "module",
  "bin": {
    "kweaver-admin": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh.md",
    "docs/SECURITY.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:cover": "vitest run --coverage",
    "ci": "npm run lint && npm run test",
    "prepublishOnly": "npm run ci && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kweaver-ai/kweaver-admin.git"
  },
  "keywords": [
    "kweaver",
    "cli",
    "admin",
    "isf"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "license": "Apache-2.0"
}
